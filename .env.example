# AI 识图 API 配置（二选一或都配，优先使用 AI_PROVIDER 指定的服务）

# 选择提供商: openai | dashscope（国内推荐 dashscope）
AI_PROVIDER=dashscope

# OpenAI（GPT-4o 视觉）
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# 阿里云通义千问（Qwen-VL）
DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_MODEL=qwen-vl-max

# 用户登录与会话
AUTH_SECRET=请替换为随机长字符串
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 短信验证码：mock（开发）| aliyun（生产）
SMS_PROVIDER=mock
SMS_MOCK_CODE=123456

# 阿里云短信（SMS_PROVIDER=aliyun 时必填）
# 控制台：https://dysms.console.aliyun.com/
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
# 模板变量名，需与短信模板一致，通常为 code
ALIYUN_SMS_TEMPLATE_PARAM=code

# 微信开放平台（网站应用扫码登录，可选）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 后台管理（品种实拍图上传）访问地址：/admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置强密码
