# AI 识图 API 配置（二选一或都配，优先使用 AI_PROVIDER 指定的服务）

# 选择提供商: openai | dashscope（国内推荐 dashscope）
AI_PROVIDER=dashscope

# OpenAI（GPT-4o 视觉）
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# 阿里云通义千问（Qwen-VL）
DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_MODEL=qwen-vl-max

# 用户登录与会话
AUTH_SECRET=请替换为随机长字符串
SMS_MOCK_CODE=123456
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 微信开放平台（网站应用扫码登录，可选）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
